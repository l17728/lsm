{
  "dashboard": {
    "id": null,
    "uid": "lsm-main-dashboard",
    "title": "LSM Project - Main Dashboard",
    "tags": ["lsm", "production"],
    "timezone": "Asia/Shanghai",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "5s",
    "panels": [
      {
        "id": 1,
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "type": "stat",
        "title": "Application Uptime",
        "targets": [
          {
            "expr": "lsm_app_uptime_seconds / 86400",
            "legendFormat": "Days"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "d",
            "decimals": 1,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto"
        }
      },
      {
        "id": 2,
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "type": "stat",
        "title": "Memory Usage",
        "targets": [
          {
            "expr": "lsm_app_memory_usage_bytes / 1024 / 1024",
            "legendFormat": "MB"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 536870912 },
                { "color": "red", "value": 1073741824 }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 3,
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "type": "stat",
        "title": "Cache Hit Rate",
        "targets": [
          {
            "expr": "lsm_cache_hit_rate_percent",
            "legendFormat": "%"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "decimals": 1,
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "yellow", "value": 70 },
                { "color": "green", "value": 85 }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "area",
          "justifyMode": "auto"
        }
      },
      {
        "id": 4,
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "type": "stat",
        "title": "Health Status",
        "targets": [
          {
            "expr": "lsm_health_status",
            "legendFormat": "Status"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "Unhealthy" } } },
              { "type": "value", "options": { "1": { "text": "Healthy" } } }
            ],
            "color": { "mode": "thresholds" },
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 1 }
              ]
            }
          }
        },
        "options": {
          "colorMode": "value",
          "graphMode": "none",
          "justifyMode": "auto"
        }
      },
      {
        "id": 5,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "type": "timeseries",
        "title": "Database Records",
        "targets": [
          {
            "expr": "lsm_db_users_total",
            "legendFormat": "Users"
          },
          {
            "expr": "lsm_db_servers_total",
            "legendFormat": "Servers"
          },
          {
            "expr": "lsm_db_tasks_total",
            "legendFormat": "Tasks"
          },
          {
            "expr": "lsm_db_gpus_total",
            "legendFormat": "GPUs"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette" },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "stacking": { "mode": "none" }
            }
          }
        },
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 6,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "type": "timeseries",
        "title": "Task Status Distribution",
        "targets": [
          {
            "expr": "lsm_db_tasks_pending",
            "legendFormat": "Pending"
          },
          {
            "expr": "lsm_db_tasks_running",
            "legendFormat": "Running"
          },
          {
            "expr": "lsm_db_tasks_completed",
            "legendFormat": "Completed"
          },
          {
            "expr": "lsm_db_tasks_failed",
            "legendFormat": "Failed"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette" },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "stacking": { "mode": "none" }
            }
          }
        },
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 7,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "type": "timeseries",
        "title": "GPU Status Distribution",
        "targets": [
          {
            "expr": "lsm_db_gpus_available",
            "legendFormat": "Available"
          },
          {
            "expr": "lsm_db_gpus_allocated",
            "legendFormat": "Allocated"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette" },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "stacking": { "mode": "none" }
            }
          }
        },
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 8,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "type": "timeseries",
        "title": "Cache Performance",
        "targets": [
          {
            "expr": "lsm_cache_hits_total",
            "legendFormat": "Hits"
          },
          {
            "expr": "lsm_cache_misses_total",
            "legendFormat": "Misses"
          },
          {
            "expr": "lsm_cache_size",
            "legendFormat": "Cache Size"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette" },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "stacking": { "mode": "none" }
            }
          }
        },
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 9,
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
        "type": "timeseries",
        "title": "Email Queue",
        "targets": [
          {
            "expr": "lsm_email_queue_pending",
            "legendFormat": "Pending"
          },
          {
            "expr": "lsm_email_queue_processing",
            "legendFormat": "Processing"
          },
          {
            "expr": "lsm_email_queue_failed",
            "legendFormat": "Failed"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette" },
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "stacking": { "mode": "none" }
            }
          }
        },
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "tooltip": { "mode": "multi" }
        }
      },
      {
        "id": 10,
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
        "type": "timeseries",
        "title": "System Health",
        "targets": [
          {
            "expr": "lsm_health_database",
            "legendFormat": "Database"
          },
          {
            "expr": "lsm_health_redis",
            "legendFormat": "Redis"
          },
          {
            "expr": "lsm_health_disk_percent / 100",
            "legendFormat": "Disk %"
          },
          {
            "expr": "lsm_health_memory_percent / 100",
            "legendFormat": "Memory %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette" },
            "unit": "percentunit",
            "custom": {
              "drawStyle": "line",
              "lineInterpolation": "linear",
              "fillOpacity": 10,
              "pointSize": 5,
              "showPoints": "never",
              "stacking": { "mode": "none" }
            }
          }
        },
        "options": {
          "legend": { "displayMode": "table", "placement": "right" },
          "tooltip": { "mode": "multi" }
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    }
  }
}
