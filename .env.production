# LSM Project - Production Environment Configuration
# Generated: 2026-03-15 (Security Fixed)
# ⚠️ DO NOT commit this file to version control!
# ⚠️ 此文件包含敏感信息，绝不应提交到版本控制系统！
# ⚠️ 请使用密钥管理服务或外部密钥存储

# ============================================
# Application Settings
# ============================================
APP_VERSION=1.0.0
NODE_ENV=production
LOG_LEVEL=info

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
DB_USER=lsm
# 🔐 SECURITY: 使用强密码，从密钥管理服务获取
# 生成命令: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER
DB_NAME=lsm
DB_PORT=5432

# ============================================
# Redis Configuration
# ============================================
# 🔐 SECURITY: 使用强密码，从密钥管理服务获取
# 生成命令: openssl rand -base64 32
REDIS_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER
REDIS_PORT=6379
REDIS_MAXMEMORY=256mb

# ============================================
# JWT Configuration
# ============================================
# 🔐 SECURITY: JWT 密钥必须从密钥管理服务获取
# 生成命令: openssl rand -base64 64
# ⚠️ 此密钥用于签名所有 JWT token，泄露将导致严重安全问题
JWT_SECRET=CHANGE_ME_USE_SECRETS_MANAGER
JWT_EXPIRES_IN=24h

# ============================================
# CORS Configuration
# ============================================
# Update these with your actual production domains
CORS_ORIGINS=https://lsm.example.com,https://www.lsm.example.com

# ============================================
# Backend Configuration
# ============================================
BACKEND_PORT=8080
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MS=5000
MONITORING_ENABLED=true
MONITORING_INTERVAL_MS=10000

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=80
VITE_API_BASE_URL=https://api.lsm.example.com/api
VITE_WS_URL=wss://api.lsm.example.com

# ============================================
# Email/SMTP Configuration
# ============================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
# 🔐 SECURITY: SMTP 密码必须从密钥管理服务获取
SMTP_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER
SMTP_FROM="LSM System <noreply@example.com>"

# ============================================
# Monitoring Configuration
# ============================================
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
# 🔐 SECURITY: Grafana 管理员密码必须从密钥管理服务获取
# 生成命令: openssl rand -base64 24
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_USE_SECRETS_MANAGER
GRAFANA_ROOT_URL=http://localhost:3000

# Exporter Ports
NODE_EXPORTER_PORT=9100
REDIS_EXPORTER_PORT=9121

# ============================================
# SSL/TLS Configuration
# ============================================
SSL_CERT_PATH=/etc/ssl/certs/lsm.example.com.crt
SSL_KEY_PATH=/etc/ssl/private/lsm.example.com.key

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_PATH=/backups
