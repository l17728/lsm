generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  username      String              @unique @db.VarChar(50)
  email         String              @unique @db.VarChar(100)
  passwordHash  String              @map("password_hash") @db.VarChar(255)
  role          user_role           @default(USER)
  metadata      Json?               @default("{}")
  createdAt     DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  lastLoginAt   DateTime?           @map("last_login_at") @db.Timestamptz(6)
  isActive      Boolean?            @default(true) @map("is_active")
  currentTeamId String?             @map("current_team_id") @db.Uuid
  alerts        Alert[]
  auditLogs     AuditLog[]
  notifications EmailNotification[]
  notificationHistory NotificationHistory[]
  allocations   GpuAllocation[]
  sessions      Session[]
  tasks         Task[]
  // 预约系统关联
  reservations           Reservation[]            // 发起的预约
  approvedReservations   Reservation[]            @relation("ApprovedReservations")   // 审批的预约
  cancelledReservations  Reservation[]            @relation("CancelledReservations")  // 取消的预约
  reservationApprovals   ReservationApproval[]   // 审批记录
  resourceQuotas         ResourceQuota[]          @relation("UserQuotas")             // 用户资源配额
  // 多租户关联
  teamMemberships       TeamMember[]              // 团队成员关系
  invitedMembers        TeamMember[]              @relation("InvitedBy")              // 邀请的成员
  currentTeam           Team?                     @relation("CurrentTeam", fields: [currentTeamId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  // 集群管理关联
  createdClusters       Cluster[]                 @relation("ClusterCreator")
  assignedClusters      Cluster[]                 @relation("ClusterAssignee")
  clusterAllocations    ClusterAllocation[]
  clusterReservations   ClusterReservation[]      // 发起的集群预约
  approvedClusterReservations ClusterReservation[] @relation("ClusterReservationApprover") // 审批的集群预约
  rejectedClusterReservations ClusterReservation[] @relation("ClusterReservationRejecter") // 拒绝的集群预约
  resourceRequests      ResourceRequest[]         @relation("Requester")
  approvedRequests      ResourceRequest[]         @relation("RequestApprover")
  requestApprovals      RequestApproval[]

  @@index([email], map: "idx_users_email")
  @@index([username], map: "idx_users_username")
  @@index([currentTeamId], map: "idx_users_current_team")
  @@map("users")
}

model Session {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  token        String    @unique
  refreshToken String?   @unique @map("refresh_token")
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz(6)
  refreshExpiresAt DateTime? @map("refresh_expires_at") @db.Timestamptz(6)
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  isRevoked    Boolean?  @default(false) @map("is_revoked")
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_sessions_token")
  @@index([userId], map: "idx_sessions_user_id")
  @@index([refreshToken], map: "idx_sessions_refresh_token")
  @@map("sessions")
}

model Server {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String         @db.VarChar(100)
  hostname    String?        @db.VarChar(100)
  description String?
  status      server_status  @default(ONLINE)
  cpuCores    Int?           @default(1) @map("cpu_cores")
  totalMemory Int?           @map("total_memory") // in GB
  gpuCount    Int            @default(0) @map("gpu_count")
  location    String?        @db.VarChar(200)
  ipAddress   String?        @map("ip_address") @db.Inet
  sshPort     Int?           @default(22) @map("ssh_port")
  sshUsername String?        @map("ssh_username") @db.VarChar(50)
  metadata    Json?          @default("{}")
  teamId      String?        @map("team_id") @db.Uuid
  createdAt   DateTime?      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  alerts      Alert[]
  gpus        Gpu[]
  metrics     ServerMetric[]
  // 预约系统关联
  reservations      Reservation[]
  reservationSlots  ReservationSlot[]
  // 多租户关联
  team              Team?            @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  // 集群管理关联
  clusterServers    ClusterServer[]

  @@index([status], map: "idx_servers_status")
  @@index([teamId], map: "idx_servers_team_id")
  @@map("servers")
}

model Gpu {
  id          String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  serverId    String          @map("server_id") @db.Uuid
  model       String          @db.VarChar(100)
  memory      Int
  allocated   Boolean?        @default(false)
  metadata    Json?           @default("{}")
  createdAt   DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  allocations GpuAllocation[]
  // 预约系统关联
  gpuReservations   GpuReservation[]
  server      Server          @relation(fields: [serverId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([allocated], map: "idx_gpus_allocated")
  @@index([serverId], map: "idx_gpus_server_id")
  @@map("gpus")
}

model GpuAllocation {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  gpuId       String    @map("gpu_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  taskId      String?   @map("task_id") @db.Uuid
  allocatedAt DateTime? @default(now()) @map("allocated_at") @db.Timestamptz(6)
  releasedAt  DateTime? @map("released_at") @db.Timestamptz(6)
  duration    Int?
  metadata    Json?     @default("{}")
  gpu         Gpu       @relation(fields: [gpuId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([gpuId], map: "idx_gpu_allocations_gpu_id")
  @@index([userId], map: "idx_gpu_allocations_user_id")
  @@map("gpu_allocations")
}

model Task {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String        @db.VarChar(200)
  description     String?
  status          task_status   @default(PENDING)
  priority        task_priority @default(MEDIUM)
  userId          String        @map("user_id") @db.Uuid
  teamId          String?       @map("team_id") @db.Uuid
  gpuRequirements Json?         @map("gpu_requirements")
  startedAt       DateTime?     @map("started_at") @db.Timestamptz(6)
  completedAt     DateTime?     @map("completed_at") @db.Timestamptz(6)
  failedAt        DateTime?     @map("failed_at") @db.Timestamptz(6)
  errorMessage    String?       @map("error_message")
  metadata        Json?         @default("{}")
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team            Team?         @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  // 预约系统关联
  reservations    Reservation[]

  @@index([priority], map: "idx_tasks_priority")
  @@index([status], map: "idx_tasks_status")
  @@index([userId], map: "idx_tasks_user_id")
  @@index([teamId], map: "idx_tasks_team_id")
  @@index([userId, status], map: "idx_tasks_user_status")
  @@index([teamId, status], map: "idx_tasks_team_status")
  @@map("tasks")
}

model ServerMetric {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  serverId    String    @map("server_id") @db.Uuid
  cpuUsage    Decimal?  @map("cpu_usage") @db.Decimal(5, 2)
  memoryUsage Decimal?  @map("memory_usage") @db.Decimal(5, 2)
  gpuUsage    Decimal?  @map("gpu_usage") @db.Decimal(5, 2)
  temperature Decimal?  @db.Decimal(5, 2)
  diskUsage   Decimal?  @map("disk_usage") @db.Decimal(5, 2)
  networkIn   BigInt?   @map("network_in")
  networkOut  BigInt?   @map("network_out")
  recordedAt  DateTime? @default(now()) @map("recorded_at") @db.Timestamptz(6)
  server      Server    @relation(fields: [serverId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([recordedAt(sort: Desc)], map: "idx_server_metrics_recorded_at")
  @@index([serverId], map: "idx_server_metrics_server_id")
  @@map("server_metrics")
}

model Alert {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type           alert_type
  status         alert_status @default(ACTIVE)
  severity       String       @default("MEDIUM") @db.VarChar(20)
  serverId       String?      @map("server_id") @db.Uuid
  message        String
  details        Json?        @default("{}")
  acknowledgedBy String?      @map("acknowledged_by") @db.Uuid
  acknowledgedAt DateTime?    @map("acknowledged_at") @db.Timestamptz(6)
  resolvedAt     DateTime?    @map("resolved_at") @db.Timestamptz(6)
  createdAt      DateTime?    @default(now()) @map("created_at") @db.Timestamptz(6)
  users          User?        @relation(fields: [acknowledgedBy], references: [id], onUpdate: NoAction)
  server         Server?      @relation(fields: [serverId], references: [id], onUpdate: NoAction)

  @@index([status], map: "idx_alerts_status")
  @@index([type], map: "idx_alerts_type")
  @@map("alerts")
}

model AuditLog {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String?   @map("user_id") @db.Uuid
  teamId       String?   @map("team_id") @db.Uuid
  action       String    @db.VarChar(100)
  resourceType String?   @map("resource_type") @db.VarChar(50)
  resourceId   String?   @map("resource_id") @db.Uuid
  details      Json?     @default("{}")
  ipAddress    String?   @map("ip_address") @db.Inet
  userAgent    String?   @map("user_agent")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User?     @relation(fields: [userId], references: [id], onUpdate: NoAction)
  team         Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([action], map: "idx_audit_logs_action")
  @@index([createdAt(sort: Desc)], map: "idx_audit_logs_created_at")
  @@index([userId], map: "idx_audit_logs_user_id")
  @@index([teamId], map: "idx_audit_logs_team_id")
  @@index([teamId, action], map: "idx_audit_logs_team_action")
  @@map("audit_logs")
}

model EmailNotification {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  type         String    @db.VarChar(50)
  subject      String    @db.VarChar(200)
  body         String
  status       String    @default("PENDING") @db.VarChar(20)
  sentAt       DateTime? @map("sent_at") @db.Timestamptz(6)
  errorMessage String?   @map("error_message")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([status], map: "idx_email_notifications_status")
  @@index([userId], map: "idx_email_notifications_user_id")
  @@map("email_notifications")
}

model ExportHistory {
  id          String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  type        export_type         @map("export_type")
  dataType    export_data_type    @map("data_type")
  status      export_status       @default(PENDING)
  filePath    String?             @map("file_path") @db.Text
  fileSize    Int?                @map("file_size")
  recordCount Int?                @map("record_count")
  filters     Json?               @default("{}")
  createdAt   DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  completedAt DateTime?           @map("completed_at") @db.Timestamptz(6)
  errorMessage String?            @map("error_message") @db.Text

  @@index([status], map: "idx_export_history_status")
  @@index([userId], map: "idx_export_history_user_id")
  @@index([createdAt(sort: Desc)], map: "idx_export_history_created_at")
  @@map("export_history")
}

model NotificationHistory {
  id        String                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String                 @map("user_id") @db.Uuid
  type      notification_type      @map("notification_type")
  severity  notification_severity
  priority  notification_priority  @default(NORMAL)
  title     String                 @db.VarChar(200)
  message   String                 @db.Text
  metadata  Json?                  @default("{}")
  isRead    Boolean                @default(false) @map("is_read")
  readAt    DateTime?              @map("read_at") @db.Timestamptz(6)
  channel   notification_channel[] @default([WEBSOCKET])
  createdAt DateTime?              @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([isRead], map: "idx_notification_history_is_read")
  @@index([userId], map: "idx_notification_history_user_id")
  @@index([createdAt(sort: Desc)], map: "idx_notification_history_created_at")
  @@index([severity], map: "idx_notification_history_severity")
  @@index([type], map: "idx_notification_history_type")
  @@unique([id, userId], map: "idx_notification_history_id_userId")
  @@map("notification_history")
}

// ==================== 原有枚举 ====================

enum notification_type {
  ALERT_CPU
  ALERT_MEMORY
  ALERT_GPU
  ALERT_TEMP
  ALERT_SERVER_OFFLINE
  TASK_CREATED
  TASK_STARTED
  TASK_COMPLETED
  TASK_FAILED
  TASK_CANCELLED
  SYSTEM_MAINTENANCE
  SYSTEM_UPDATE
  SYSTEM_RESTART
  BATCH_STARTED
  BATCH_PROGRESS
  BATCH_COMPLETED
  BATCH_FAILED
  USER_LOGIN
  USER_LOGOUT
  USER_KICKED
}

enum notification_severity {
  CRITICAL
  WARNING
  INFO
  SUCCESS
}

enum notification_priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum notification_channel {
  EMAIL
  DINGTALK
  WEBSOCKET
  SMS
}

enum export_type {
  CSV
  EXCEL
  PDF
}

enum export_data_type {
  SERVERS
  GPUS
  TASKS
  USERS
  METRICS
}

enum export_status {
  PENDING
  COMPLETED
  FAILED
}

enum alert_status {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

enum alert_type {
  HIGH_CPU
  HIGH_MEMORY
  HIGH_GPU
  HIGH_TEMP
  SERVER_OFFLINE
}

enum server_status {
  ONLINE
  OFFLINE
  MAINTENANCE
  ERROR
}

enum task_priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum task_status {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum user_role {
  SUPER_ADMIN  // 超级管理员 - 集群管理、资源调配
  ADMIN        // 系统管理员 - 系统配置
  MANAGER      // 资源管理员 - 申请资源
  USER         // 普通用户
}

// ==================== 多租户枚举 ====================

enum team_status {
  ACTIVE      // 活跃
  SUSPENDED   // 暂停
  ARCHIVED    // 归档
}

enum team_role {
  OWNER    // 团队所有者
  ADMIN    // 团队管理员
  MEMBER   // 普通成员
}

// ==================== 预约系统枚举 ====================

enum reservation_status {
  PENDING      // 待审批
  APPROVED     // 已批准
  REJECTED     // 已拒绝
  ACTIVE       // 进行中（已开始）
  COMPLETED    // 已完成
  CANCELLED    // 已取消
  EXPIRED      // 已过期（未在规定时间开始）
}

enum approval_status {
  PENDING      // 待审批
  APPROVED     // 已批准
  REJECTED     // 已拒绝
}

enum slot_status {
  AVAILABLE    // 可预约
  RESERVED     // 已预约
  BLOCKED      // 已锁定（维护等）
}

enum quota_type {
  USER         // 用户级配额
  TEAM         // 团队级配额
  ROLE         // 角色级配额
  GLOBAL       // 全局配额
}

// ==================== 多租户模型 ====================

model Team {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String      @unique @db.VarChar(100)
  slug        String      @unique @db.VarChar(50)
  description String?     @db.Text
  logoUrl     String?     @map("logo_url") @db.VarChar(500)
  status      team_status @default(ACTIVE)
  settings    Json?       @default("{}")
  createdBy   String      @map("created_by") @db.Uuid
  createdAt   DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  members       TeamMember[]
  quotas        ResourceQuota[]
  servers       Server[]
  tasks         Task[]
  reservations  Reservation[]
  auditLogs     AuditLog[]
  currentUsers  User[]        @relation("CurrentTeam")
  clusterAllocations ClusterAllocation[]

  @@index([slug], map: "idx_teams_slug")
  @@index([status], map: "idx_teams_status")
  @@map("teams")
}

model TeamMember {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  teamId    String    @map("team_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      team_role @default(MEMBER)
  joinedAt  DateTime? @default(now()) @map("joined_at") @db.Timestamptz(6)
  invitedBy String?  @map("invited_by") @db.Uuid
  metadata  Json?     @default("{}")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  team    Team  @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user    User  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  inviter User? @relation("InvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@unique([teamId, userId], map: "idx_team_members_unique")
  @@index([teamId], map: "idx_team_members_team_id")
  @@index([userId], map: "idx_team_members_user_id")
  @@index([teamId, userId], map: "idx_team_members_team_user")
  @@map("team_members")
}

// ==================== 预约系统模型 ====================

model Reservation {
  id               String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId           String              @map("user_id") @db.Uuid
  serverId         String              @map("server_id") @db.Uuid
  teamId           String?             @map("team_id") @db.Uuid
  title            String              @db.VarChar(200)
  description      String?             @db.Text
  status           reservation_status  @default(PENDING)
  startTime        DateTime            @map("start_time") @db.Timestamptz(6)
  endTime          DateTime            @map("end_time") @db.Timestamptz(6)
  actualStartTime  DateTime?           @map("actual_start_time") @db.Timestamptz(6)
  actualEndTime    DateTime?           @map("actual_end_time") @db.Timestamptz(6)
  gpuCount         Int                 @default(0) @map("gpu_count")
  cpuCores         Int?                @map("cpu_cores")
  memoryGb         Int?                @map("memory_gb")
  taskId           String?             @map("task_id") @db.Uuid
  approvedBy       String?             @map("approved_by") @db.Uuid
  approvedAt       DateTime?           @map("approved_at") @db.Timestamptz(6)
  rejectionReason  String?             @map("rejection_reason") @db.Text
  cancelledBy      String?             @map("cancelled_by") @db.Uuid
  cancelledAt      DateTime?           @map("cancelled_at") @db.Timestamptz(6)
  cancelReason     String?             @map("cancel_reason") @db.Text
  metadata         Json?               @default("{}")
  createdAt        DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  server           Server              @relation(fields: [serverId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team             Team?               @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  task             Task?               @relation(fields: [taskId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  approver         User?               @relation("ApprovedReservations", fields: [approvedBy], references: [id], onDelete: SetNull, onUpdate: NoAction)
  canceller        User?               @relation("CancelledReservations", fields: [cancelledBy], references: [id], onDelete: SetNull, onUpdate: NoAction)
  gpuReservations  GpuReservation[]
  approvals        ReservationApproval[]
  slots            ReservationSlot[]

  @@index([userId], map: "idx_reservations_user_id")
  @@index([serverId], map: "idx_reservations_server_id")
  @@index([status], map: "idx_reservations_status")
  @@index([startTime], map: "idx_reservations_start_time")
  @@index([endTime], map: "idx_reservations_end_time")
  @@index([userId, status], map: "idx_reservations_user_status")
  @@index([serverId, status], map: "idx_reservations_server_status")
  @@index([startTime, endTime], map: "idx_reservations_time_range")
  @@index([teamId], map: "idx_reservations_team_id")
  @@index([teamId, status], map: "idx_reservations_team_status")
  @@map("reservations")
}

model GpuReservation {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reservationId   String      @map("reservation_id") @db.Uuid
  gpuId           String      @map("gpu_id") @db.Uuid
  allocatedAt     DateTime?   @map("allocated_at") @db.Timestamptz(6)
  releasedAt      DateTime?   @map("released_at") @db.Timestamptz(6)
  metadata        Json?       @default("{}")
  createdAt       DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)

  reservation     Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  gpu             Gpu         @relation(fields: [gpuId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([reservationId, gpuId], map: "idx_gpu_reservations_unique")
  @@index([gpuId], map: "idx_gpu_reservations_gpu_id")
  @@index([reservationId], map: "idx_gpu_reservations_reservation_id")
  @@map("gpu_reservations")
}

model ReservationApproval {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reservationId   String          @map("reservation_id") @db.Uuid
  approverId      String          @map("approver_id") @db.Uuid
  status          approval_status @default(PENDING)
  level           Int             @default(1)
  comment         String?         @db.Text
  approvedAt      DateTime?       @map("approved_at") @db.Timestamptz(6)
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  reservation     Reservation     @relation(fields: [reservationId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  approver        User            @relation(fields: [approverId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([reservationId], map: "idx_reservation_approvals_reservation_id")
  @@index([approverId], map: "idx_reservation_approvals_approver_id")
  @@index([status], map: "idx_reservation_approvals_status")
  @@unique([reservationId, level], map: "idx_reservation_approvals_unique_level")
  @@map("reservation_approvals")
}

model ReservationSlot {
  id              String        @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  serverId        String        @map("server_id") @db.Uuid
  startTime       DateTime      @map("start_time") @db.Timestamptz(6)
  endTime         DateTime      @map("end_time") @db.Timestamptz(6)
  status          slot_status   @default(AVAILABLE)
  reservationId   String?       @map("reservation_id") @db.Uuid
  blockReason     String?       @map("block_reason") @db.VarChar(255)
  metadata        Json?         @default("{}")
  createdAt       DateTime?     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  server          Server        @relation(fields: [serverId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reservation     Reservation?  @relation(fields: [reservationId], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([serverId], map: "idx_reservation_slots_server_id")
  @@index([serverId, startTime, endTime], map: "idx_reservation_slots_time_range")
  @@index([status], map: "idx_reservation_slots_status")
  @@index([reservationId], map: "idx_reservation_slots_reservation_id")
  @@map("reservation_slots")
}

model ResourceQuota {
  id                  String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  quotaType           quota_type  @map("quota_type")
  targetId            String?     @map("target_id") @db.Uuid
  teamId              String?     @map("team_id") @db.Uuid
  maxServers          Int?        @map("max_servers")
  maxServerHours      Int?        @map("max_server_hours")
  maxGpus             Int?        @map("max_gpus")
  maxGpuHours         Int?        @map("max_gpu_hours")
  maxReservationDays  Int?        @map("max_reservation_days")
  maxAdvanceDays      Int?        @map("max_advance_days")
  maxConcurrent       Int?        @map("max_concurrent")
  effectiveFrom       DateTime?   @map("effective_from") @db.Timestamptz(6)
  effectiveUntil      DateTime?   @map("effective_until") @db.Timestamptz(6)
  metadata            Json?       @default("{}")
  createdAt           DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  user                User?       @relation("UserQuotas", fields: [targetId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  team                Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([quotaType, targetId, teamId], map: "idx_resource_quotas_unique_target")
  @@index([quotaType], map: "idx_resource_quotas_type")
  @@index([targetId], map: "idx_resource_quotas_target_id")
  @@index([teamId], map: "idx_resource_quotas_team_id")
  @@map("resource_quotas")
}

// ==================== 集群管理枚举 ====================

enum cluster_status {
  AVAILABLE     // 可用 - 可分配给申请者
  ALLOCATED     // 已分配 - 正在被使用
  RESERVED      // 已预约 - 等待使用时间
  MAINTENANCE   // 维护中
  OFFLINE       // 离线
}

enum cluster_type {
  COMPUTE       // 计算集群
  TRAINING      // 训练集群  
  INFERENCE     // 推理集群
  GENERAL       // 通用集群
  CUSTOM        // 自定义
}

enum request_status {
  DRAFT         // 草稿
  PENDING       // 待审批
  APPROVED      // 已批准
  REJECTED      // 已拒绝
  FULFILLED     // 已交付
  CANCELLED     // 已取消
  EXPIRED       // 已过期
}

enum request_priority {
  LOW
  NORMAL
  HIGH
  CRITICAL      // 关键任务
  URGENT        // 紧急
}

// ==================== 集群管理模型 ====================

// 集群定义
model Cluster {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name            String          @unique @db.VarChar(100)
  code            String          @unique @db.VarChar(50)
  description     String?         @db.Text
  type            cluster_type    @default(GENERAL)
  status          cluster_status  @default(AVAILABLE)
  
  // 资源配置
  totalServers    Int             @default(0) @map("total_servers")
  totalGpus       Int             @default(0) @map("total_gpus")
  totalCpuCores   Int             @default(0) @map("total_cpu_cores")
  totalMemory     Int             @default(0) @map("total_memory")
  
  // 使用情况
  usedServers     Int             @default(0) @map("used_servers")
  usedGpus        Int             @default(0) @map("used_gpus")
  
  // 分配信息
  assignedTo      String?         @map("assigned_to") @db.Uuid
  assignedAt      DateTime?       @map("assigned_at") @db.Timestamptz(6)
  assignmentEnd   DateTime?       @map("assignment_end") @db.Timestamptz(6)
  
  // 标签和元数据
  tags            Json?           @default("[]")
  capabilities    Json?           @default("{}")
  constraints     Json?           @default("{}")
  metadata        Json?           @default("{}")
  
  // 审计
  createdBy       String          @map("created_by") @db.Uuid
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  // 关联
  servers         ClusterServer[]
  allocations     ClusterAllocation[]
  reservations    ClusterReservation[]  // 集群预约
  requests        ResourceRequest[]
  creator         User            @relation("ClusterCreator", fields: [createdBy], references: [id])
  assignee        User?           @relation("ClusterAssignee", fields: [assignedTo], references: [id])
  
  @@index([status], map: "idx_clusters_status")
  @@index([type], map: "idx_clusters_type")
  @@index([assignedTo], map: "idx_clusters_assigned_to")
  @@map("clusters")
}

// 集群-服务器关联
model ClusterServer {
  id          String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clusterId   String      @map("cluster_id") @db.Uuid
  serverId    String      @map("server_id") @db.Uuid
  addedAt     DateTime?   @default(now()) @map("added_at") @db.Timestamptz(6)
  addedBy     String?     @map("added_by") @db.Uuid
  priority    Int         @default(0)
  role        String?     @db.VarChar(50)
  metadata    Json?       @default("{}")
  
  cluster     Cluster     @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  server      Server      @relation(fields: [serverId], references: [id], onDelete: Cascade)
  
  @@unique([clusterId, serverId], map: "idx_cluster_servers_unique")
  @@index([clusterId], map: "idx_cluster_servers_cluster_id")
  @@index([serverId], map: "idx_cluster_servers_server_id")
  @@map("cluster_servers")
}

// 集群分配记录
model ClusterAllocation {
  id              String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clusterId       String      @map("cluster_id") @db.Uuid
  userId          String      @map("user_id") @db.Uuid
  teamId          String?     @map("team_id") @db.Uuid
  
  startTime       DateTime    @map("start_time") @db.Timestamptz(6)
  endTime         DateTime    @map("end_time") @db.Timestamptz(6)
  actualStart     DateTime?   @map("actual_start") @db.Timestamptz(6)
  actualEnd       DateTime?   @map("actual_end") @db.Timestamptz(6)
  
  requestId       String?     @unique @map("request_id") @db.Uuid
  purpose         String?     @db.Text
  status          String      @default("ACTIVE")
  
  gpuHours        Decimal?    @map("gpu_hours") @db.Decimal(10, 2)
  cost            Decimal?    @db.Decimal(12, 2)
  
  metadata        Json?       @default("{}")
  createdAt       DateTime?   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  cluster         Cluster     @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  team            Team?       @relation(fields: [teamId], references: [id], onDelete: SetNull)
  request         ResourceRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  
  @@index([clusterId], map: "idx_cluster_allocations_cluster_id")
  @@index([userId], map: "idx_cluster_allocations_user_id")
  @@index([startTime, endTime], map: "idx_cluster_allocations_time_range")
  @@map("cluster_allocations")
}

// 集群预约 - MANAGER 用户预约集群使用
model ClusterReservation {
  id              String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  clusterId       String    @map("cluster_id") @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  teamId          String?   @map("team_id") @db.Uuid
  
  // 预约时间
  startTime       DateTime  @map("start_time") @db.Timestamptz(6)
  endTime         DateTime  @map("end_time") @db.Timestamptz(6)
  purpose         String?   @db.Text
  
  // 状态: PENDING(待审批) -> APPROVED(已批准) -> ACTIVE(使用中) -> COMPLETED(已完成)
  // 或: PENDING -> REJECTED(已拒绝) / CANCELLED(已取消)
  status          String    @default("PENDING")
  
  // 审批信息 (需要 SUPER_ADMIN 审批)
  approvedBy      String?   @map("approved_by") @db.Uuid
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz(6)
  rejectedBy      String?   @map("rejected_by") @db.Uuid
  rejectedAt      DateTime? @map("rejected_at") @db.Timestamptz(6)
  rejectionReason String?   @map("rejection_reason") @db.Text
  
  // 等待队列 (时间冲突时排队)
  queuePosition   Int?      @map("queue_position")
  
  // 实际使用时间
  actualStartTime DateTime? @map("actual_start_time") @db.Timestamptz(6)
  actualEndTime   DateTime? @map("actual_end_time") @db.Timestamptz(6)
  
  metadata        Json?     @default("{}")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  // 关联
  cluster         Cluster   @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  approver        User?     @relation("ClusterReservationApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  rejecter        User?     @relation("ClusterReservationRejecter", fields: [rejectedBy], references: [id], onDelete: SetNull)
  
  @@index([clusterId, status], map: "idx_cluster_reservations_cluster_status")
  @@index([userId, status], map: "idx_cluster_reservations_user_status")
  @@index([status, startTime], map: "idx_cluster_reservations_status_time")
  @@index([clusterId, startTime, endTime], map: "idx_cluster_reservations_time_range")
  @@map("cluster_reservations")
}

// 资源申请
model ResourceRequest {
  id              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  requestCode     String              @unique @map("request_code") @db.VarChar(50)
  requesterId     String              @map("requester_id") @db.Uuid
  teamId          String?             @map("team_id") @db.Uuid
  
  title           String              @db.VarChar(200)
  description     String?             @db.Text
  purpose         String?             @db.Text
  
  minServers      Int?                @map("min_servers")
  maxServers      Int?                @map("max_servers")
  minGpus         Int?                @map("min_gpus")
  maxGpus         Int?                @map("max_gpus")
  minCpuCores     Int?                @map("min_cpu_cores")
  minMemory       Int?                @map("min_memory")
  gpuModel        String?             @map("gpu_model") @db.VarChar(100)
  
  startTime       DateTime            @map("start_time") @db.Timestamptz(6)
  endTime         DateTime            @map("end_time") @db.Timestamptz(6)
  duration        Int?
  
  status          request_status      @default(DRAFT)
  priority        request_priority    @default(NORMAL)
  
  approvedBy      String?             @map("approved_by") @db.Uuid
  approvedAt      DateTime?           @map("approved_at") @db.Timestamptz(6)
  rejectionReason String?             @map("rejection_reason") @db.Text
  
  assignedClusterId String?           @map("assigned_cluster_id") @db.Uuid
  optimizationResult Json?            @map("optimization_result")
  optimizationMode  String?           @map("optimization_mode") @db.VarChar(20)
  
  constraints     Json?               @default("{}")
  metadata        Json?               @default("{}")
  createdAt       DateTime?           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  
  requester       User                @relation("Requester", fields: [requesterId], references: [id])
  approver        User?               @relation("RequestApprover", fields: [approvedBy], references: [id])
  assignedCluster Cluster?            @relation(fields: [assignedClusterId], references: [id], onDelete: SetNull)
  allocation      ClusterAllocation?
  approvals       RequestApproval[]
  
  @@index([requesterId], map: "idx_resource_requests_requester_id")
  @@index([status], map: "idx_resource_requests_status")
  @@index([priority], map: "idx_resource_requests_priority")
  @@index([startTime, endTime], map: "idx_resource_requests_time_range")
  @@index([teamId], map: "idx_resource_requests_team_id")
  @@map("resource_requests")
}

// 申请审批记录
model RequestApproval {
  id              String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  requestId       String          @map("request_id") @db.Uuid
  approverId      String          @map("approver_id") @db.Uuid
  level           Int             @default(1)
  status          approval_status @default(PENDING)
  comment         String?         @db.Text
  approvedAt      DateTime?       @map("approved_at") @db.Timestamptz(6)
  createdAt       DateTime?       @default(now()) @map("created_at") @db.Timestamptz(6)
  
  request         ResourceRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver        User            @relation(fields: [approverId], references: [id], onDelete: Cascade)
  
  @@unique([requestId, level], map: "idx_request_approvals_unique_level")
  @@index([requestId], map: "idx_request_approvals_request_id")
  @@index([approverId], map: "idx_request_approvals_approver_id")
  @@map("request_approvals")
}