generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  USER
}

enum ServerStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  ERROR
}

enum TaskStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum AlertType {
  HIGH_CPU
  HIGH_MEMORY
  HIGH_GPU
  HIGH_TEMP
  SERVER_OFFLINE
}

enum AlertStatus {
  ACTIVE
  ACKNOWLEDGED
  RESOLVED
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  username      String    @unique @db.VarChar(50)
  email         String    @unique @db.VarChar(100)
  passwordHash  String    @map("password_hash") @db.VarChar(255)
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  lastLoginAt   DateTime? @map("last_login_at")
  isActive      Boolean   @default(true) @map("is_active")
  
  sessions      Session[]
  allocations   GpuAllocation[]
  tasks         Task[]
  auditLogs     AuditLog[]
  notifications EmailNotification[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique @db.Text
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  isRevoked Boolean  @default(false) @map("is_revoked")

  @@map("sessions")
}

model Server {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @db.VarChar(100)
  description String?      @db.Text
  status      ServerStatus @default(OFFLINE)
  gpuCount    Int          @default(0) @map("gpu_count")
  location    String?      @db.VarChar(200)
  ipAddress   String?      @map("ip_address") @db.Inet
  sshPort     Int?         @default(22) @map("ssh_port")
  sshUsername String?      @map("ssh_username") @db.VarChar(50)
  metadata    Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  
  gpus        Gpu[]
  metrics     ServerMetric[]
  alerts      Alert[]

  @@map("servers")
}

model Gpu {
  id         String        @id @default(uuid()) @db.Uuid
  serverId   String        @map("server_id") @db.Uuid
  server     Server        @relation(fields: [serverId], references: [id], onDelete: Cascade)
  model      String        @db.VarChar(100)
  memory     Int           @db.Integer
  allocated  Boolean       @default(false)
  metadata   Json          @default("{}")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  
  allocations GpuAllocation[]

  @@map("gpus")
}

model GpuAllocation {
  id          String   @id @default(uuid()) @db.Uuid
  gpuId       String   @map("gpu_id") @db.Uuid
  gpu         Gpu      @relation(fields: [gpuId], references: [id], onDelete: Cascade)
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String?  @map("task_id") @db.Uuid
  allocatedAt DateTime @default(now()) @map("allocated_at")
  releasedAt  DateTime? @map("released_at")
  duration    Int?     @db.Integer
  metadata    Json     @default("{}")

  @@map("gpu_allocations")
}

model Task {
  id             String       @id @default(uuid()) @db.Uuid
  name           String       @db.VarChar(200)
  description    String?      @db.Text
  status         TaskStatus   @default(PENDING)
  priority       TaskPriority @default(MEDIUM)
  userId         String       @map("user_id") @db.Uuid
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  gpuRequirements Json?       @map("gpu_requirements") @db.JsonB
  startedAt      DateTime?    @map("started_at")
  completedAt    DateTime?    @map("completed_at")
  failedAt       DateTime?    @map("failed_at")
  errorMessage   String?      @map("error_message") @db.Text
  metadata       Json         @default("{}")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("tasks")
}

model ServerMetric {
  id           String   @id @default(uuid()) @db.Uuid
  serverId     String   @map("server_id") @db.Uuid
  server       Server   @relation(fields: [serverId], references: [id], onDelete: Cascade)
  cpuUsage     Decimal? @map("cpu_usage") @db.Decimal(5, 2)
  memoryUsage  Decimal? @map("memory_usage") @db.Decimal(5, 2)
  gpuUsage     Decimal? @map("gpu_usage") @db.Decimal(5, 2)
  temperature  Decimal? @db.Decimal(5, 2)
  diskUsage    Decimal? @map("disk_usage") @db.Decimal(5, 2)
  networkIn    BigInt?  @map("network_in")
  networkOut   BigInt?  @map("network_out")
  recordedAt   DateTime @default(now()) @map("recorded_at")

  @@map("server_metrics")
  @@index([serverId])
  @@index([recordedAt(DESC)])
}

model Alert {
  id             String     @id @default(uuid()) @db.Uuid
  type           AlertType
  status         AlertStatus @default(ACTIVE)
  severity       String     @default("MEDIUM") @db.VarChar(20)
  serverId       String?    @map("server_id") @db.Uuid
  server         Server?    @relation(fields: [serverId], references: [id], onDelete: SetNull)
  message        String     @db.Text
  details        Json       @default("{}") @db.JsonB
  acknowledgedBy String?    @map("acknowledged_by") @db.Uuid
  acknowledgedAt DateTime?  @map("acknowledged_at")
  resolvedAt     DateTime?  @map("resolved_at")
  createdAt      DateTime   @default(now()) @map("created_at")

  @@map("alerts")
  @@index([status])
  @@index([type])
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   @db.VarChar(100)
  resourceType String? @map("resource_type") @db.VarChar(50)
  resourceId  String?  @map("resource_id") @db.Uuid
  details     Json     @default("{}") @db.JsonB
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
  @@index([userId])
  @@index([action])
  @@index([createdAt(DESC)])
}

model EmailNotification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   @db.VarChar(50)
  subject   String   @db.VarChar(200)
  body      String   @db.Text
  status    String   @default("PENDING") @db.VarChar(20)
  sentAt    DateTime? @map("sent_at")
  errorMessage String? @map("error_message") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_notifications")
  @@index([userId])
  @@index([status])
}
